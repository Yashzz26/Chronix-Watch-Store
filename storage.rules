rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos — user can read anyone's, but only write their own
    match /profile-photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Product images — anyone can read, only authenticated admins can upload
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
