PORT=5000
NODE_ENV=production
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
FRONTEND_URL=your_frontend_vercel_url
ADMIN_URL=your_admin_vercel_url
MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=your_msg91_sender_id
MSG91_OTP_TEMPLATE_ID=your_otp_template_id
# Firebase Admin (Base64 encoded serviceAccountKey.json)
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_json
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email
SMTP_PASS=your_app_password
EMAIL_FROM="Chronix Support <no-reply@yourdomain.com>"
